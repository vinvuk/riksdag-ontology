{
  "@context": {
    "@vocab": "https://ontology.riksdagen.se/def/",
    "rksdag": "https://ontology.riksdagen.se/def/",
    "rksdagd": "https://data.riksdagen.se/id/",
    "rksdagv": "https://ontology.riksdagen.se/vocab/",
    "eli": "http://data.europa.eu/eli/ontology#",
    "org": "http://www.w3.org/ns/org#",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "MemberOfParliament": "rksdag:MemberOfParliament",
    "PoliticalParty": "rksdag:PoliticalParty",
    "Committee": "rksdag:Committee",
    "GovernmentBill": "rksdag:GovernmentBill",
    "Motion": "rksdag:Motion",
    "CommitteeReport": "rksdag:CommitteeReport",
    "Interpellation": "rksdag:Interpellation",
    "WrittenQuestion": "rksdag:WrittenQuestion",
    "VotingEvent": "rksdag:VotingEvent",
    "Ballot": "rksdag:Ballot",
    "Speech": "rksdag:Speech",
    "Statute": "rksdag:Statute",
    "ParliamentarySession": "rksdag:ParliamentarySession",

    "intressentId": { "@id": "rksdag:intressentId", "@type": "xsd:string" },
    "dokId": { "@id": "rksdag:dokId", "@type": "xsd:string" },
    "designation": { "@id": "rksdag:designation", "@type": "xsd:string" },
    "voteringId": { "@id": "rksdag:voteringId", "@type": "xsd:string" },
    "speechId": { "@id": "rksdag:speechId", "@type": "xsd:string" },
    "sessionId": { "@id": "rksdag:sessionId", "@type": "xsd:string" },
    "sfsNumber": { "@id": "rksdag:sfsNumber", "@type": "xsd:string" },
    "organCode": { "@id": "rksdag:organCode", "@type": "xsd:string" },
    "partyAbbreviation": { "@id": "rksdag:partyAbbreviation", "@type": "xsd:string" },

    "givenName": "foaf:givenName",
    "familyName": "foaf:familyName",
    "birthYear": { "@id": "rksdag:birthYear", "@type": "xsd:gYear" },
    "gender": { "@id": "rksdag:gender", "@type": "xsd:string" },
    "imageUrl": { "@id": "rksdag:imageUrl", "@type": "@id" },

    "documentTitle": { "@id": "rksdag:documentTitle", "@language": "sv" },
    "documentDate": { "@id": "rksdag:documentDate", "@type": "xsd:date" },
    "decisionDate": { "@id": "rksdag:decisionDate", "@type": "xsd:date" },
    "debateDate": { "@id": "rksdag:debateDate", "@type": "xsd:date" },
    "entryIntoForceDate": { "@id": "rksdag:entryIntoForceDate", "@type": "xsd:date" },
    "electionDate": { "@id": "rksdag:electionDate", "@type": "xsd:date" },
    "voteDate": { "@id": "rksdag:voteDate", "@type": "xsd:date" },
    "startDate": { "@id": "rksdag:startDate", "@type": "xsd:date" },
    "endDate": { "@id": "rksdag:endDate", "@type": "xsd:date" },
    "consolidationDate": { "@id": "rksdag:consolidationDate", "@type": "xsd:date" },
    "eventDate": { "@id": "rksdag:eventDate", "@type": "xsd:date" },

    "yesCount": { "@id": "rksdag:yesCount", "@type": "xsd:nonNegativeInteger" },
    "noCount": { "@id": "rksdag:noCount", "@type": "xsd:nonNegativeInteger" },
    "abstainCount": { "@id": "rksdag:abstainCount", "@type": "xsd:nonNegativeInteger" },
    "absentCount": { "@id": "rksdag:absentCount", "@type": "xsd:nonNegativeInteger" },
    "pointNumber": { "@id": "rksdag:pointNumber", "@type": "xsd:nonNegativeInteger" },
    "mandateCount": { "@id": "rksdag:mandateCount", "@type": "xsd:nonNegativeInteger" },
    "speechNumber": { "@id": "rksdag:speechNumber", "@type": "xsd:nonNegativeInteger" },

    "author": { "@id": "rksdag:author", "@type": "@id" },
    "handledBy": { "@id": "rksdag:handledBy", "@type": "@id" },
    "hasMembership": { "@id": "rksdag:hasMembership", "@type": "@id" },
    "inOrganization": { "@id": "rksdag:inOrganization", "@type": "@id" },
    "hasRole": { "@id": "rksdag:hasRole", "@type": "@id" },
    "partOfSession": { "@id": "rksdag:partOfSession", "@type": "@id" },
    "references": { "@id": "rksdag:references", "@type": "@id" },
    "respondsTo": { "@id": "rksdag:respondsTo", "@type": "@id" },
    "basedOn": { "@id": "rksdag:basedOn", "@type": "@id" },
    "implementedBy": { "@id": "rksdag:implementedBy", "@type": "@id" },
    "resultsIn": { "@id": "rksdag:resultsIn", "@type": "@id" },
    "amends": { "@id": "rksdag:amends", "@type": "@id" },
    "repeals": { "@id": "rksdag:repeals", "@type": "@id" },
    "voter": { "@id": "rksdag:voter", "@type": "@id" },
    "voteOption": { "@id": "rksdag:voteOption", "@type": "@id" },
    "onDocument": { "@id": "rksdag:onDocument", "@type": "@id" },
    "hasBallot": { "@id": "rksdag:hasBallot", "@type": "@id" },
    "speaker": { "@id": "rksdag:speaker", "@type": "@id" },
    "partOfDebate": { "@id": "rksdag:partOfDebate", "@type": "@id" },
    "representsDistrict": { "@id": "rksdag:representsDistrict", "@type": "@id" },
    "followsUp": { "@id": "rksdag:followsUp", "@type": "@id" },
    "addressedTo": { "@id": "rksdag:addressedTo", "@type": "@id" }
  }
}
