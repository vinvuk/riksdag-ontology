@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix rksdag: <https://ontology.riksdagen.se/def/> .

# =============================================================================
# SHACL Shapes — Voting Module Validation
# =============================================================================

rksdag:VotingEventShape
    a sh:NodeShape ;
    sh:targetClass rksdag:VotingEvent ;
    sh:property [
        sh:path rksdag:voteringId ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "voterings-ID"@sv ;
    ] ;
    sh:property [
        sh:path rksdag:voteDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rksdag:onDocument ;
        sh:class rksdag:CommitteeReport ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rksdag:yesCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rksdag:noCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rksdag:abstainCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rksdag:absentCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
    ] .

rksdag:BallotShape
    a sh:NodeShape ;
    sh:targetClass rksdag:Ballot ;
    sh:property [
        sh:path rksdag:voter ;
        sh:class rksdag:MemberOfParliament ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "röstande"@sv ;
        sh:message "Varje röst måste tillhöra exakt en ledamot."@sv ;
    ] ;
    sh:property [
        sh:path rksdag:voteOption ;
        sh:class skos:Concept ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "röstval"@sv ;
        sh:message "Varje röst måste ha exakt ett röstval."@sv ;
    ] ;
    sh:property [
        sh:path rksdag:inVotingEvent ;
        sh:class rksdag:VotingEvent ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
