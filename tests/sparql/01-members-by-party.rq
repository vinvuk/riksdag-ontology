# Competency Q1: List all current members and their party affiliation
PREFIX rksdag: <https://ontology.riksdagen.se/def/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?name ?party ?district
WHERE {
    ?person a rksdag:MemberOfParliament ;
            foaf:givenName ?fname ;
            foaf:familyName ?lname ;
            rksdag:hasMembership ?membership .
    ?membership a rksdag:PartyMembership ;
                rksdag:inOrganization ?partyOrg .
    ?partyOrg rksdag:partyAbbreviation ?party .
    FILTER NOT EXISTS { ?membership rksdag:endDate ?end }
    BIND(CONCAT(?fname, " ", ?lname) AS ?name)
}
ORDER BY ?party ?lname
LIMIT 20
