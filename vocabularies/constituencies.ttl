@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rksdagv: <https://ontology.riksdagen.se/vocab/> .

# =============================================================================
# SKOS Concept Scheme — Electoral Districts (Valkretsar)
# =============================================================================

rksdagv:ConstituencyScheme
    a skos:ConceptScheme ;
    skos:prefLabel "Valkretsar"@sv , "Electoral Districts"@en ;
    dcterms:description
        "De 29 valkretsarna för val till Sveriges riksdag."@sv ,
        "The 29 electoral districts for elections to the Swedish Riksdag."@en ;
    dcterms:created "2026-03-19"^^xsd:date .

rksdagv:constituency-stockholms-kommun
    a skos:Concept ;
    skos:inScheme rksdagv:ConstituencyScheme ;
    skos:prefLabel "Stockholms kommun"@sv , "Stockholm Municipality"@en .

