@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rksdagv: <https://ontology.riksdagen.se/vocab/> .

# =============================================================================
# SKOS Concept Scheme — Expenditure Areas (Utgiftsområden)
# =============================================================================

rksdagv:ExpenditureAreaScheme
    a skos:ConceptScheme ;
    skos:prefLabel "Utgiftsområden"@sv , "Expenditure Areas"@en ;
    dcterms:description
        """Sveriges 27 utgiftsområden i statsbudgeten enligt rambeslutsmodellen."""@sv ,
        """Sweden's 27 expenditure areas in the state budget under the framework decision model."""@en ;
    dcterms:created "2026-03-19"^^xsd:date .

rksdagv:uo-1
    a skos:Concept ;
    skos:inScheme rksdagv:ExpenditureAreaScheme ;
    skos:notation "1" ;
    skos:prefLabel "Rikets styrelse"@sv , "Central Government"@en .

