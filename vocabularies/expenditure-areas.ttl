    a skos:Concept ;
    skos:inScheme rksdagv:ExpenditureAreaScheme ;
    skos:notation "2" ;
    skos:prefLabel "Samhällsekonomi och finansförvaltning"@sv ,
                   "National Economy and Financial Management"@en .

